# ── Backend ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (replace placeholders)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of the database inside the cluster
DB_NAME=taskmanager

# Flask session signing key — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Set to true only in local dev to bypass strict TLS cert checks
TLS_INSECURE=false

# Set to true when serving over HTTPS (required in production)
SESSION_COOKIE_SECURE=false

# Comma-separated list of allowed CORS origins
# Local dev:  http://localhost:5173
# Production: https://yourapp.duckdns.org
CORS_ORIGINS=http://localhost:5173

# Enable Flask debug mode in local dev only — never true in production
FLASK_DEBUG=false
